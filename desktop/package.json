{
  "name": "strainspotter-desktop",
  "version": "1.0.0",
  "description": "StrainSpotter Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "generate-icons": "bash scripts/generate-icons.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.strainspotter.app",
    "productName": "StrainSpotter",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
