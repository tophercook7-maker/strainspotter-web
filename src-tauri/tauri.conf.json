{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "StrainSpotter",
  "version": "0.1.0",
  "identifier": "app.strainspotter.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "StrainSpotter",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600,
        "url": "https://app.strainspotter.app"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src https://app.strainspotter.app https://*.supabase.co https://*.googleapis.com; img-src 'self' https: data:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/512x512@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
