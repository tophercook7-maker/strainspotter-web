# Dataset Ops — copy to .env.dataset and fill in paths. Do NOT commit .env.dataset.
DATASET_ROOT=/Volumes/TheVault/StrainSpotter-Dataset
HERO_ROOT=/Volumes/TheVault/AI-Hero-Images
# HERO_DIR is an alias for HERO_ROOT

# Download controls
PER_STRAIN_MAX_NEW=3
SEARCH_LIMIT=12
MIN_BYTES=40000
MIN_WIDTH=400
MIN_HEIGHT=400
REQUEST_TIMEOUT_MS=15000
DELAY_MS=500

# Bing Image Search (Azure Cognitive Services)
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com
BING_SEARCH_KEY=YOUR_BING_KEY_HERE

# Monster dataset safety knobs
DATASET_MAX_DOWNLOAD_CONCURRENCY=3
DATASET_BING_RPS=2
DATASET_PER_STRAIN_MAX_IMAGES=3
DATASET_IMAGE_MIN_BYTES=25000
DATASET_HTTP_TIMEOUT_MS=15000
DATASET_RETRY_MAX=3
