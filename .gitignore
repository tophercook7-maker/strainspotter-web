# ===============================
# BLOCK EVERYTHING THAT IS NOT THE NEXT.JS WEB APP
# ===============================

# Tooling / experiments
pipeline-control/
scripts/
ml-training/
supabase/functions/
supabase/_shared/
__quarantine__/
env/
logs/

# Desktop / native
src-tauri/
tauri.conf.json

# Local/editor
.vscode/
.DS_Store

# macOS Finder / iCloud collision copies (e.g. "page 2.tsx", "route 3.ts")
# These get auto-created when files conflict during sync. Always safe to ignore.
* 2.ts
* 2.tsx
* 2.js
* 2.jsx
* 2.json
* 2.md
* 2.sql
* 2.css
* 2.example
* 2.html
* 2.jsonl
* 3.ts
* 3.tsx
* 3.js
* 3.jsx
* 3.json
* 3.md

# Node noise
node_modules/

# Ignore everything by default
*

# ===============================
# ALLOW ONLY THE WEB APP
# ===============================
!app/
!app/**
!components/
!components/**
!styles/
!styles/**
!public/
!next.config.*
!package.json
!package-lock.json
!tsconfig.json
!postcss.config.js
!tailwind.config.js
!GLASS_UI*.md
!CLAUDE_HANDOFF_STRAINSPOTTER.md
# ===============================
# ALLOW DESKTOP APP
# ===============================
!desktop/
!desktop/strainspotter-desktop/
!desktop/strainspotter-desktop/**
!lib/
!lib/**

# ===============================
# ENVIRONMENT / SECRETS (never commit)
# ===============================
.env
.env.local
.env.dataset
.env.pipeline.local
.env.*.local

# Example / template env files (safe to commit)
!.env.example
!.env.local.example
!.env.dataset.example