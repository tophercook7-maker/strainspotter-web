logs/

# Desktop / native
src-tauri/
tauri.conf.json

# Local/editor
.vscode/
.DS_Store
.env.local
.env.dataset

# Backup / temp files
*.bak
*.bak*
*_backup
*.before_grid
*.backup

# Node noise
node_modules/

# Ignore everything by default
*

