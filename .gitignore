# ===============================
# BLOCK EVERYTHING THAT IS NOT THE NEXT.JS WEB APP
# ===============================

# Tooling / experiments
pipeline-control/
scripts/
ml-training/
supabase/functions/
supabase/_shared/
__quarantine__/
env/
logs/

# Desktop / native
src-tauri/
tauri.conf.json

# Local/editor
.vscode/
.DS_Store

# Node noise
node_modules/

# Ignore everything by default
*

# ===============================
# ALLOW ONLY THE WEB APP
# ===============================
!app/
!public/
!next.config.*
!package.json
!package-lock.json
!tsconfig.json
!postcss.config.js
!tailwind.config.js
!desktop/strainspotter-desktop/**
# ===============================
# ALLOW DESKTOP APP
# ===============================
!desktop/
!desktop/strainspotter-desktop/
!desktop/strainspotter-desktop/**