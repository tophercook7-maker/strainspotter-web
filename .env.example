# StrainSpotter Web — Environment Variables
# ==========================================
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. NEVER commit real secrets.

# ─────────────────────────────────────────────────────────
# REQUIRED — the app will not function without these
# ─────────────────────────────────────────────────────────

# OpenAI — powers the GPT-4o Vision scanner at /api/scan
OPENAI_API_KEY=sk-...

# Supabase — auth, profiles, scan history, references
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
# Some scripts read SUPABASE_SERVICE_ROLE_KEY instead — set both to the same value:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────
# REQUIRED for billing flows — leave blank if not using Stripe
# ─────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────
# OPTIONAL — Garden Console
# ─────────────────────────────────────────────────────────

# Shared secret for POST /api/garden/console/ingest (header: x-ingest-key).
# Production denies if unset.
GARDEN_CONSOLE_INGEST_KEY=

# ─────────────────────────────────────────────────────────
# OPTIONAL — backend base URL (legacy / external scan API)
# ─────────────────────────────────────────────────────────

NEXT_PUBLIC_API_BASE=

# ─────────────────────────────────────────────────────────
# OPTIONAL — Scanner cost / mode flags (legacy CLIP pipeline)
# Current scanner uses GPT-4o directly; these are read by the
# older orchestrator paths and the npm `scanner:*` scripts.
# ─────────────────────────────────────────────────────────

SCANNER_AI_PROVIDER=off          # off | openai
SCANNER_COST_MODE=free           # free | paid
SCANNER_USE_OPENAI_ON_SCAN=false
SCANNER_MATCHING_MODE=embedding  # embedding | hybrid | name-first
SCANNER_DEBUG_MATCHING=false
SCANNER_AUTO_RECALIBRATE=false
SCANNER_DISABLE_FEEDBACK_PRIOR=false
SCANNER_DISABLE_PROVIDER_BOOST=false
SCANNER_EMBEDDING_MODEL=Xenova/clip-vit-base-patch32

# ─────────────────────────────────────────────────────────
# OPTIONAL — External reference image search providers
# Only needed by `npm run scanner:image-lake` and related
# maintenance scripts. Keep `off` unless actively building
# the reference library.
# ─────────────────────────────────────────────────────────

REFERENCE_IMAGE_SEARCH_PROVIDER=off   # off | brave | google | serpapi | bing
REFERENCE_SOURCE=

BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_DAILY_LIMIT=
BRAVE_SEARCH_MAX_QUERIES_PER_RUN=
BRAVE_SEARCH_REQUIRE_CONFIRM=true

GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=
GOOGLE_SEARCH_DAILY_LIMIT=
GOOGLE_SEARCH_MAX_QUERIES_PER_RUN=
GOOGLE_SEARCH_REQUIRE_CONFIRM=true

SERPAPI_API_KEY=
SERPAPI_DAILY_LIMIT=
SERPAPI_MAX_QUERIES_PER_RUN=
SERPAPI_REQUIRE_CONFIRM=true

BING_IMAGE_SEARCH_API_KEY=

# ─────────────────────────────────────────────────────────
# OPTIONAL — Reference / training storage roots (TheVault)
# Used by maintenance scripts. Defaults to local repo paths
# if unset, but production data lives on TheVault external disk:
#   /Volumes/TheVault/StrainSpotter/reference-images/
# ─────────────────────────────────────────────────────────

REFERENCE_IMAGE_STORAGE_ROOT=
SCANNER_TRAINING_STORAGE_ROOT=
STRAINSPOTTER_WEB_ROOT=

SUPABASE_REFERENCE_BUCKET=scanner-reference-images
SUPABASE_REFERENCE_RAW_BUCKET=scanner-reference-raw-images
SUPABASE_TRAINING_BUCKET=scanner-training-images

# ─────────────────────────────────────────────────────────
# OPTIONAL — third-party strain data providers
# ─────────────────────────────────────────────────────────

STRAIN_DATA_PROVIDERS=
STRAINCOMPASS_API_KEY=
STRAINCOMPASS_BASE_URL=
TERPSCOUT_API_KEY=
